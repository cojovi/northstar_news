# Supabase Configuration (Required)
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Optional API Keys for Future Features
# ElevenLabs API (for text-to-speech article reading)
VITE_ELEVENLABS_API_KEY=your_elevenlabs_api_key

# OpenAI API (for AI-powered features)
VITE_OPENAI_API_KEY=your_openai_api_key

# Feature Flags (true/false)
# Enable/disable visual effects for performance
VITE_ENABLE_GRADIENT_EFFECTS=true
VITE_ENABLE_PARTICLE_EFFECTS=true
VITE_ENABLE_AMBIENT_BACKGROUND=true
VITE_ENABLE_GLASSMORPHIC_UI=true
